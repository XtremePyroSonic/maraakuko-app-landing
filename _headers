# Cloudflare Pages _headers — controls Content-Type for the
# .well-known/* files. Apple requires apple-app-site-association
# to be served with `Content-Type: application/json` (and crucially
# WITHOUT a `.json` file extension on the URL path). Google's
# assetlinks.json verifier also requires application/json.

/.well-known/apple-app-site-association
  Content-Type: application/json
  Cache-Control: public, max-age=300

/.well-known/assetlinks.json
  Content-Type: application/json
  Cache-Control: public, max-age=300

# Hosted legal pages (generated by scripts/gen_legal_pages.py from the
# app's legal_documents.dart). Cache modestly so policy edits propagate
# within the hour.
/legal/*
  Cache-Control: public, max-age=3600

# Security headers — applied site-wide. Workers Assets applies all
# matching header rules cumulatively, so these stack on top of the
# Content-Type / Cache-Control rules above.
/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  X-Frame-Options: DENY
  Permissions-Policy: camera=(), microphone=(), geolocation=()

# Fingerprint-stable fonts can cache for a year.
/assets/fonts/*
  Cache-Control: public, max-age=31536000, immutable

# CSS/JS/images: 7 days. The ?v=N query param in index.html is the
# cache-bust lever — bump it whenever you change site.css / site.js.
/assets/*
  Cache-Control: public, max-age=604800
